Grammar

    0 $accept: program $end

    1 program: func_list

    2 func_list: func_list function
    3          | function

    4 function: INT IDENT '(' param_list_opt ')' compound_stmt

    5 param_list_opt: /* empty */
    6               | param_list

    7 param_list: INT IDENT
    8           | param_list ',' INT IDENT

    9 compound_stmt: '{' stmt_list_opt '}'

   10 stmt_list_opt: /* empty */
   11              | stmt_list

   12 stmt_list: stmt_list stmt
   13          | stmt

   14 stmt: vardecl ';'
   15     | RETURN expr ';'
   16     | expr ';'
   17     | if_stmt
   18     | while_stmt
   19     | for_stmt

   20 if_stmt: IF '(' expr ')' compound_stmt
   21        | IF '(' expr ')' compound_stmt ELSE compound_stmt

   22 while_stmt: WHILE '(' expr ')' compound_stmt

   23 for_stmt: FOR '(' for_init_opt ';' for_cond_opt ';' for_increment_opt ')' compound_stmt

   24 for_init_opt: /* empty */
   25             | INT IDENT
   26             | INT IDENT '=' expr
   27             | expr

   28 for_cond_opt: /* empty */
   29             | expr

   30 for_increment_opt: /* empty */
   31                  | expr

   32 vardecl: INT IDENT
   33        | INT IDENT '=' expr

   34 expr: expr '+' expr
   35     | expr '-' expr
   36     | expr '*' expr
   37     | expr '/' expr
   38     | expr EQ expr
   39     | expr NE expr
   40     | expr LT expr
   41     | expr GT expr
   42     | expr LE expr
   43     | expr GE expr
   44     | IDENT '=' expr
   45     | primary

   46 primary: NUMBER
   47        | IDENT
   48        | IDENT '(' arg_list_opt ')'
   49        | '(' expr ')'

   50 arg_list_opt: /* empty */
   51             | arg_list

   52 arg_list: expr
   53         | arg_list ',' expr


